{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": { "noConsole": "error" },
      "style": { "useConst": "error", "noNonNullAssertion": "error" },
      "complexity": { "useLiteralKeys": "error" }
    }
  }
}
